# =============================================================================
# Cursor Composer (recommended for hackathon demo)
# =============================================================================
# 1. Get key: Cursor Dashboard -> Integrations
# 2. In one terminal: scripts/start_cursor_proxy.ps1
# 3. In another: scripts/start_all_agents.ps1
# LLM_BACKEND=cursor
# CURSOR_API_KEY=your_crsr_key
# OPENAI_API_BASE=http://127.0.0.1:8787/v1
# OPENAI_API_KEY=local
# LLM_MODEL=composer-2.5

# =============================================================================
# Baseten — https://www.baseten.co (Model API, OpenAI-compatible)
# =============================================================================
# LLM_BACKEND=baseten
# BASETEN_API_KEY=your_baseten_key
# OPENAI_API_BASE=https://inference.baseten.co/v1
# LLM_MODEL=openai/gpt-oss-120b
# LLM_MAX_TOKENS=4096

# =============================================================================
# Ollama (local or Railway / remote host)
# =============================================================================
# LLM_BACKEND=ollama
# OPENAI_API_BASE=https://your-ollama-host.up.railway.app/v1
# LLM_MODEL=llama3.2
# OPENAI_API_KEY=ollama
# On the host first: ollama pull llama3.2

# =============================================================================
# OllamaFreeAPI — free community Ollama pool (https://github.com/mfoud444/ollamafreeapi)
# =============================================================================
# LLM_BACKEND=ollamafreeapi
# OLLAMAFREEAPI_BASE_URL=http://host:11434
# LLM_MODEL=llama3.2:latest
# pip install ollamafreeapi

# =============================================================================
# Groq — https://console.groq.com
# =============================================================================
# LLM_BACKEND=groq
# GROQ_API_KEY=your_groq_key
# LLM_MODEL=llama-3.3-70b-versatile

# Cerebras — https://cloud.cerebras.ai
# LLM_BACKEND=cerebras
# CEREBRAS_API_KEY=your_cerebras_key
# LLM_MODEL=gpt-oss-120b
# LLM_MAX_TOKENS=4096

# PERMITOS_ORCHESTRATION=auto
# BAND_QUICK_TIMEOUT=120

BAND_WS_URL=wss://app.band.ai/api/v1/socket/websocket
BAND_REST_URL=https://app.band.ai
# Seconds to wait for Band agents to respond (default 300)
# BAND_ORCHESTRATION_TIMEOUT=600

DATABASE_URL=sqlite+aiosqlite:///./permitos.db
API_HOST=0.0.0.0
API_PORT=8000
