# Copy these into Render → Web Service → Environment
# Secrets: paste your real keys (never commit this file with real values)

# === LLM (match local .env) ===
LLM_BACKEND=baseten
BASETEN_API_KEY=your_baseten_key
OPENAI_API_BASE=https://inference.baseten.co/v1
LLM_MODEL=openai/gpt-oss-120b
LLM_MAX_TOKENS=4096
LLM_MAX_RETRIES=8

# === Band orchestration (match local .env) ===
PERMITOS_ORCHESTRATION=band
BAND_ORCHESTRATION_TIMEOUT=600
BAND_WS_URL=wss://app.band.ai/api/v1/socket/websocket
BAND_REST_URL=https://app.band.ai
SPECIALIST_STAGGER_SEC=90
SPECIALIST_COMPLETE_COOLDOWN_SEC=30
BAND_AGENT_SILENCE_SEC=240
BAND_AGENT_QUOTA_RESTART_SEC=90
BAND_AGENT_RESTART_SEC=30

# Serialize LLM calls across 4 agent processes (Render all-in-one; prevents 429s)
LLM_CROSS_PROCESS_LOCK=1
LLM_MIN_INTERVAL_SEC=4

# === Agent config (pick one) ===
AGENT_CONFIG_PATH=/etc/secrets/agent_config.yaml

# === Database ===
DATABASE_URL=sqlite+aiosqlite:///./data/permitos.db

# === Optional: Groq is more reliable on Render than Baseten free tier ===
# LLM_BACKEND=groq
# GROQ_API_KEY=your_groq_key
# OPENAI_API_BASE=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
# SPECIALIST_STAGGER_SEC=45
